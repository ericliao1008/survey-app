# ====== 生产环境必须设置 ======
# 管理员登录密码（访问 /stats/:slug 与 CSV 导出时需要输入）
# 请用强随机字符串，例如：python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# ====== 可选 ======
# DEBUG=false  # 生产必须 false；true 会打开 /docs 和 SQL echo
# DEBUG=false

# SQLite 数据库路径。生产推荐挂载持久 volume：
# DATABASE_URL=sqlite:////data/survey.db
# DATABASE_URL=sqlite:////data/survey.db

# CORS 允许的前端源（一体化部署可留空或保留）
# CORS_ORIGINS=https://your-app.zeabur.app
