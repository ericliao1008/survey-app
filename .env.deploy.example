# 服务器部署用环境变量模板
# 复制为 .env 后填写真实值（.env 已被 .gitignore 排除，不会上传）
#
#   cp .env.deploy.example .env
#   nano .env

# 1) 你绑定的域名（必须先把 DNS A 记录指到本机公网 IP）
DOMAIN=survey.deeocem.online

# 2) 后台管理员密码 —— 强随机字符串，至少 32 位
#    生成方法：openssl rand -base64 32
ADMIN_TOKEN=please_replace_with_a_strong_random_string

# 3) 是否强制重新加载 surveys/*.json（会清空对应问卷的所有答卷）
#    日常保持 false。仅在导出 CSV 后想覆盖问卷结构时改为 true，
#    redeploy 之后再立刻改回 false。
FORCE_RELOAD_SURVEYS=false
