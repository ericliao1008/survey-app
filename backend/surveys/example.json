      }
    },
    {
      "type": "text_short",
      "text": "【仅对推荐分 0-6 分者显示】是什么让您难以推荐本系统？",
      "required": false,
      "config": {
        "placeholder": "请直言不讳，这对我们很重要",
        "show_if": {
          "question_order": 4,
          "operator": "lte",
          "value": 6
        }
      }
    },
    {
      "type": "text_long",
      "text": "您有什么其他建议或意见？",
      "required": false,
      "config": {"placeholder": "请畅所欲言……"}
    }
  ]
